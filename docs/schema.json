    "/profiles/api/notifications/unsubscribe": {
      "post": {
        "operationId": "unsubscribe_notifications",
        "description": "Verify HMAC token and toggle the corresponding notification preference off. Uses POST per RFC 8058 (List-Unsubscribe-Post).\n\n**Permissions:** `AllowAny`",
