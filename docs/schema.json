      "ProfileFieldManifestEntry": {
        "type": "object",
        "description": "One active profile field, as the frontend skin needs it to render\nitself without hardcoding field names (docs/pending/profile-fields.md,\n\"Дополнение владельца\" §1 — data-driven skin, tier 1 of the two-tier\nfront-pair answer). GET /profiles/api/v1/field-manifest/ returns a list\nof these for whatever the project's STAPEL_PROFILES[\"FIELDS\"] manifest\n(identity preset + standard_fields + custom_fields) actually selected.",
        "properties": {
          "name": {
            "type": "string",
            "description": "Field name",
            "example": "theme"
          },
          "kind": {
            "type": "string",
            "description": "Storage/presentation kind (text, bool, enum, model_ref, geohash)",
            "example": "enum"
          },
          "docstring": {
            "type": "string",
            "description": "Human-readable field description, feeds help text",
            "example": "UI theme preference."
          },
          "required": {
            "type": "boolean",
            "description": "Whether the field is required (not blank)"
          },
          "order": {
            "type": "integer",
            "description": "Manifest declaration order — identity first, then standard_fields in listed order, then custom_fields"
          },
          "enum_values": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true,
            "description": "Choice values, only present when kind is enum",
            "example": [
              "light",
              "dark",
              "system"
            ]
          }
        },
        "required": [
          "docstring",
          "kind",
          "name",
          "order",
          "required"
        ]
      },
      "ProfilePublic": {
        "type": "object",
        "description": "Compact serializer for viewing other user's profile.",
        "properties": {
          "user_id": {
            "type": "string",
            "format": "uuid",
            "description": "User UUID from auth service"
          },
          "avatar_source": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AvatarSourceEnum"
              }
            ],
            "description": "Where `avatar` points: uploaded file key, arbitrary URL, Gravatar email-hash, or a CDN ref. Defaults to file/url — cdn is opt-in, not the default.\n\n* `file` - File\n* `url` - URL\n* `gravatar` - Gravatar\n* `cdn` - CDN"
          },
          "avatar": {
            "type": "string",
            "nullable": true,
            "description": "Avatar reference matching avatar_source: CDN 'avatar/<hash>' ref, a Gravatar email-hash, a plain URL, or an uploaded file key.",
            "maxLength": 500
          },
          "avatar_image": {
            "allOf": [
              {
                "$ref": "#/components/schemas/StapelImage"
              }
            ],
            "readOnly": true
          },
          "location_id": {
            "type": "integer",
            "maximum": 9223372036854775807,
            "minimum": -9223372036854775808,
            "format": "int64",
            "nullable": true,
            "description": "User's location ID from geo service"
          },
          "location_display_name_narrow": {
            "type": "string",
            "description": "Cached narrow location display name from geo service",
            "maxLength": 255
          },
          "location_display_name_broad": {
            "type": "string",
            "description": "Cached broad location display name from geo service",
            "maxLength": 255
          },
          "followers_count": {
            "type": "integer",
            "description": "Get count of users following this profile.",
            "readOnly": true
          },
          "following_count": {
            "type": "integer",
            "description": "Get count of users this profile is following.",
            "readOnly": true
          },
          "relationship_status": {
            "type": "string",
            "nullable": true,
            "description": "Get relationship status with current user.",
            "readOnly": true
          }
        },
        "required": [
          "avatar_image",
          "followers_count",
          "following_count",
          "relationship_status",
          "user_id"
        ]
      },
